# Copy to .env.local (or .env) for local dev.

# Storefront → Fastify API (must end with /api, no trailing slash after "api")
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Optional: same secret as the backend if you use auth / middleware (defaults exist in code)
# JWT_SECRET=change-me

# Show PayRam on checkout; set 1 to hide
# NEXT_PUBLIC_HIDE_PAYRAM=1
# NEXT_PUBLIC_PAYRAM_ENVIRONMENT=testnet
